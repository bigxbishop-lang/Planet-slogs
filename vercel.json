{
  "buildCommand": "pnpm --filter @workspace/slugs-nft run build",
  "outputDirectory": "artifacts/slugs-nft/.next",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
